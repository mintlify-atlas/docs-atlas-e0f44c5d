{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Social Media Activity Feed API",
  "theme": "aspen",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#1E40AF"
  },
  "navbar": {
