          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/architecture",
              "concepts/authentication",
              "concepts/pagination",
              "concepts/database-design"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/user-management",
              "guides/social-graph",
              "guides/posts-interactions",
              "guides/activity-feed"
            ]
          }
        ]
      },
      {
