  "keyFeatures": [
    "JWT Bearer Authentication",
    "Cursor-based Pagination for Activity Feed",
    "Composite Primary Keys for Data Integrity",
    "Minimal API with Feature-Module Organization",
    "Social Graph (Follow/Block/Close Friends)",
    "Post Interactions (Likes/Comments/Saves)",
    "N+1 Query Prevention via Projection",
    "Atomic Operations for Relationship Toggles"
  ],
  "publicApiSurface": [
    "POST /api/register",
    "POST /api/login",
    "PUT /api/users/{username}",
    "DELETE /api/users/{username}",
    "POST /api/users/{creatorUsername}/follow",
    "DELETE /api/users/{creatorUsername}/follow",
    "GET /api/users/{username}/followers",
    "GET /api/users/{username}/following",
    "POST /api/users/{username}/block",
    "DELETE /api/users/{username}/block",
    "POST /api/users/{username}/close-friends",
    "DELETE /api/users/{username}/close-friends",
    "POST /api/posts",
    "GET /api/posts/{id}",
    "DELETE /api/posts/{id}",
    "POST /api/posts/{id}/restore",
    "POST /api/posts/{id}/like",
    "DELETE /api/posts/{id}/like",
    "POST /api/posts/{id}/comment",
    "DELETE /api/posts/{id}/comment",
    "POST /api/posts/{id}/save",
    "DELETE /api/posts/{id}/save",
    "GET /api/feed/{username}",
    "GET /api/notifications"
  ]
