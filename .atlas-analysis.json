  "projectDescription": "A high-performance RESTful API for social graphs, follower feeds, and interaction primitives built with ASP.NET Core Minimal APIs.",
  "theme": "aspen",
  "primaryColor": "#3B82F6",
  "lightColor": "#60A5FA",
